# ── Ilutzim — production environment template (Railway) ─────────────────────
# These are the Variables to set on the Railway service. Do NOT commit real
# values. Generate the secrets with: bash scripts/gen_secrets.sh

# Environment — enables secret fail-fast and disables the __DEV_MODE__ bypass.
ENVIRONMENT=production

# Database — MUST be the asyncpg URL (alembic + the engine read it directly).
# On Railway, build it from the Postgres plugin's reference variables:
# DATABASE_URL=postgresql+asyncpg://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/${{Postgres.PGDATABASE}}
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Telegram — the production bot token (a separate bot from dev).
TELEGRAM_BOT_TOKEN=your-production-bot-token

# Single origin served by the backend.
APP_URL=https://app.example.com

# Secrets — generate with scripts/gen_secrets.sh
JWT_SECRET_KEY=replace-with-64-hex-chars
ADMIN_API_KEY=replace-with-random-string

# Feature flag — hide schedule builder + constraints import in production.
SCHEDULE_BUILDER_ENABLED=false

# Automation (in-process APScheduler cron).
AUTO_ROLLOVER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Jerusalem

# Seed admin (idempotent on first boot). Password policy: >=10 chars, letter+digit.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-with-strong-password-1
SEED_ADMIN_FULL_NAME=System Admin

# Logging / retention (defaults shown; optional).
LOG_LEVEL=INFO
RETENTION_ENABLED=true
RETENTION_WEEKS=60
