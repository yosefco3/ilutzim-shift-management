DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ilutzim
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/ilutzim
# Telegram bot token — the ONLY source for the token (not editable from the UI).
# Changing it requires restarting the backend.
TELEGRAM_BOT_TOKEN=your-bot-token-here
APP_URL=https://app.example.com
ADMIN_API_KEY=your-admin-api-key
# JWT_SECRET_KEY — must be a strong, random, unique value (>= 32 chars).
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
# In production the app refuses to start if this is missing/short/a demo value.
# Real value is set on the server only — never commit it to git.
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO
# ENVIRONMENT: dev | staging | production. Fail-closed — the DEFAULT is
# production. Anything that is not exactly "dev" rejects weak secrets and the
# __DEV_MODE__ auth bypass (fail-fast). Local dev MUST set ENVIRONMENT=dev.
ENVIRONMENT=dev
# Guard-auth bypass for local dev only (header X-Telegram-Init-Data: __DEV_MODE__).
# Ignored (and refuses to boot) unless ENVIRONMENT=dev.
DEV_AUTH_BYPASS_ENABLED=true
CRON_WEEKLY_OPEN_DAY=sunday
CRON_WEEKLY_OPEN_HOUR=09:00

# Seed — default admin user (python -m app.seed)
# SEED_ADMIN_PASSWORD policy: >= 10 chars, at least one letter and one digit.
# Real value is set on the server only — never commit it to git.
SEED_ADMIN_EMAIL=admin@test.com
SEED_ADMIN_PASSWORD=change-me-strong-1
SEED_ADMIN_FULL_NAME=Test Admin

# Stage 3 — attendance system (Telegram punch -> admin UI -> payroll export).
# Off by default; the code ships dormant. Frontend counterpart: VITE_ATTENDANCE_ENABLED.
ATTENDANCE_ENABLED=false
